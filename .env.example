# =============================================================
# Transcript Tool — Environment Variables
# Copy file này thành .env và điền giá trị thật
# TUYỆT ĐỐI không commit file .env lên git
# =============================================================

# ------- Google Gemini -------
# Lấy tại: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ------- STT Provider — chọn 1 -------
# AssemblyAI: https://www.assemblyai.com/
ASSEMBLYAI_API_KEY=

# Deepgram (thay thế): https://console.deepgram.com/
# DEEPGRAM_API_KEY=

# Gladia (nếu cần code-switching Anh-Việt): https://www.gladia.io/
# GLADIA_API_KEY=

# STT provider đang dùng (assemblyai | deepgram | gladia)
STT_PROVIDER=assemblyai

# ------- Supabase -------
# Lấy tại: Settings > API trong Supabase dashboard
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=   # chỉ dùng ở server, KHÔNG bao giờ expose ra client

# ------- OpenRouter (optional) -------
# https://openrouter.ai/keys
# Key 1: không gắn thẻ → dùng model :free cho việc không nhạy cảm
OPENROUTER_FREE_KEY=
# Key 2: gắn thẻ → dùng model trả phí cho transcript (sensitive)
OPENROUTER_PAID_KEY=

# ------- Server config -------
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# ------- Frontend (VITE_*) -------
# Chỉ đặt những giá trị KHÔNG nhạy cảm ở đây
# API keys TUYỆT ĐỐI không đặt dưới dạng VITE_*
VITE_API_URL=http://localhost:3001
VITE_WS_URL=ws://localhost:3001
