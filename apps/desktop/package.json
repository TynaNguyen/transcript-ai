{
  "name": "transcript-ai-desktop",
  "version": "1.0.0",
  "description": "Transcript AI — native desktop app",
  "homepage": "https://github.com/TynaNguyen/transcript-ai",
  "author": {
    "name": "Tyna Nguyen",
    "email": "giangnguyenpr96@gmail.com"
  },
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsc && electron .",
    "build:ts": "tsc",
    "build:server": "cd ../server && npx @vercel/ncc build src/index.ts -o ../../apps/desktop/bundled-server --transpile-only",
    "build:web": "cd ../web && npm run build",
    "build": "npm run build:web && npm run build:server && npm run build:ts && electron-builder",
    "pack": "electron-builder --dir",
    "release": "npm run build:web && npm run build:server && npm run build:ts && electron-builder --publish always"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "@types/electron": "^1.6.10",
    "electron": "31.0.0",
    "electron-builder": "24.13.3",
    "typescript": "^5.4.5"
  },
  "build": {
    "appId": "com.transcriptai.desktop",
    "productName": "Transcript AI",
    "directories": {
      "output": "release"
    },
    "extraResources": [
      {
        "from": "bundled-server",
        "to": "bundled-server",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../web/dist",
        "to": "web-dist",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../../.env",
        "to": ".env"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "entitlements": "build/entitlements.mac.plist",
      "hardenedRuntime": true,
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "publish": {
      "provider": "github",
      "owner": "TynaNguyen",
      "repo": "transcript-ai"
    }
  }
}
